              "example": {
                "pin": 1234,
                "amount": 100.0
              }
            }
          }
        },
        "responses": {
          "404": {
            "description": "Not Found - The card does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                },
                "example": {
                  "message": "There is no card with the identifier `$identifier`.",
                  "code": 404
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - The volunteer is not authorized to update the card",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                },
                "example": {
                  "message": "You are not allowed to perform this action",
                  "code": 403
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - The amount is not a valid number",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                },
                "example": {
                  "message": "The amount needs to be positive",
                  "code": 400
                }
              }
            }
          },
          "200": {
            "description": "Card successfully updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                },
                "example": {
                  "message": "The card has been successfully updated",
                  "code": 200
                }
              }
            }
          }
        },
        "security": [
          {
            "api": []
          }
        ]
      }
    },
    "/api/v1/cards": {
      "post": {
        "summary": "Create card",
        "description": "This endpoint creates a new card. The request body should contain the card nfc, pin.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReceiveCreateCard",
                "example": {
                  "nfc": "",
                  "pin": 1234
                }
              }
            }
          }
        },
        "responses": {
          "409": {
            "description": "Conflict - The card already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                },
                "example": {
                  "message": "This card already exists",
                  "code": 409
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - The volunteer is not authorized to update the card",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                },
                "example": {
                  "message": "You are not allowed to perform this action",
                  "code": 403
                }
              }
            }
          },
          "201": {
            "description": "Card successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                },
                "example": {
                  "message": "The card was created with success",
                  "code": 201
                }
              }
            }
          }
        },
        "security": [
          {
            "api": []
          }
        ]
      }
    },
